# ── Postgres ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://roche:roche@localhost:5432/rocheradar

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM Providers (env-var fallbacks; DB settings take precedence) ────────
# Vertex AI (Gemini) — default provider
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west4
VERTEX_AI_PRO_MODEL=gemini-2.5-pro
VERTEX_AI_FLASH_MODEL=gemini-2.5-flash
# Path to GCP service account JSON (or use workload identity / gcloud ADC)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# OpenRouter  (openrouter.ai)
OPENROUTER_API_KEY=

# Anthropic  (console.anthropic.com)
ANTHROPIC_API_KEY=

# OpenAI  (platform.openai.com)
OPENAI_API_KEY=

# NVIDIA NIM  (build.nvidia.com)
NVIDIA_API_KEY=

# Google AI Studio / Gemini  (aistudio.google.com)
GEMINI_API_KEY=

# Ollama — no key needed; set base URL in app settings (default: http://localhost:11434)

# ── TinyFish ──────────────────────────────────────────────
TINYFISH_API_KEY=
TINYFISH_API_KEYS=key1,key2,key3

# ── ChromaDB ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=rocheradar_posts

# ── Sentry ────────────────────────────────────────────────
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────
SECRET_KEY=changeme-at-least-32-chars-long!!
ENVIRONMENT=development
LOG_LEVEL=INFO
REPORTS_DIR=/app/reports

# ── Pipeline ──────────────────────────────────────────────
DAILY_RUN_HOUR=8
DAILY_RUN_MINUTE=0
AGENT_BUDGET_PER_RUN=250
LLM_BUDGET_HARD_STOP=500
DEDUP_COSINE_THRESHOLD=0.95
