# ── Postgres ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://roche:roche@localhost:5432/rocheradar

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Vertex AI / LiteLLM ───────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west4
VERTEX_AI_PRO_MODEL=gemini-2.5-pro
VERTEX_AI_FLASH_MODEL=gemini-2.5-flash
# Path to GCP service account JSON (or use workload identity in prod)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json

# ── TinyFish ──────────────────────────────────────────────
TINYFISH_API_KEY=
TINYFISH_API_KEYS=key1,key2,key3

# ── ChromaDB ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=rocheradar_posts

# ── Sentry ────────────────────────────────────────────────
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────
SECRET_KEY=changeme-at-least-32-chars-long!!
ENVIRONMENT=development
LOG_LEVEL=INFO
REPORTS_DIR=/app/reports

# ── Pipeline ──────────────────────────────────────────────
DAILY_RUN_HOUR=8
DAILY_RUN_MINUTE=0
AGENT_BUDGET_PER_RUN=250
LLM_BUDGET_HARD_STOP=500
DEDUP_COSINE_THRESHOLD=0.95
