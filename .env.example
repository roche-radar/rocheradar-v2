# ═══════════════════════════════════════════════════════════
#  RocheRadar v2 — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────
# Local dev — matches docker-compose.dev.yml
DATABASE_URL=postgresql+asyncpg://roche:roche@localhost:5432/rocheradar
# Railway: use the DATABASE_URL provided by Railway PostgreSQL plugin
# (Railway provides postgresql://... which is auto-converted to asyncpg)

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM Providers ──────────────────────────────────────────
# Primary: Gemini (Google AI Studio) — fast, cheap
GEMINI_API_KEY=

# Fallback: NVIDIA NIM — auto-used if Gemini fails
NVIDIA_API_KEY=

# Other providers (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Vertex AI (GCP) — only if using google cloud directly
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=europe-west4
GOOGLE_APPLICATION_CREDENTIALS=

# ── TinyFish ───────────────────────────────────────────────
TINYFISH_API_KEY=
# Multiple keys for round-robin rotation (comma separated, no spaces)
TINYFISH_API_KEYS=key1,key2,key3
# Rate limit per key: 30 for free tier, 300+ for premium
TINYFISH_RATE_LIMIT_PER_KEY=30

# ── ChromaDB ───────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8002
CHROMA_COLLECTION=rocheradar_posts

# ── App ────────────────────────────────────────────────────
# Change this to a long random string in production
SECRET_KEY=changeme-at-least-32-chars-long!!
ENVIRONMENT=development
LOG_LEVEL=INFO

# Reports storage — use a persistent volume path in production
REPORTS_DIR=./reports

# Internal trigger URL — set to your Railway backend URL in production
# e.g. https://rocheradar-backend.railway.app/api/runs/trigger
RUN_TRIGGER_URL=http://localhost:8009/api/runs/trigger

# ── Pipeline ───────────────────────────────────────────────
DAILY_RUN_HOUR=8
DAILY_RUN_MINUTE=0
AGENT_BUDGET_PER_RUN=250
LLM_BUDGET_HARD_STOP=500
DEDUP_COSINE_THRESHOLD=0.95

# ── Monitoring (optional) ──────────────────────────────────
SENTRY_DSN=
