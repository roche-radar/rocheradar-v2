{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "build": {
        "builder": "DOCKERFILE",
        "context": "backend"
      },
      "deploy": {
        "startCommand": "sh -c \"alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port $PORT --workers 2\"",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    },
    "worker-scrape": {
      "build": {
        "builder": "DOCKERFILE",
        "context": "backend"
      },
      "deploy": {
        "startCommand": "sh -c \"celery -A app.tasks.celery_app.celery_app worker -Q scrape --concurrency=6 --loglevel=info -n scrape@railway\"",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    },
    "worker-llm": {
      "build": {
        "builder": "DOCKERFILE",
        "context": "backend"
      },
      "deploy": {
        "startCommand": "sh -c \"celery -A app.tasks.celery_app.celery_app worker -Q llm --concurrency=8 --loglevel=info -n llm@railway\"",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    },
    "worker-pdf": {
      "build": {
        "builder": "DOCKERFILE",
        "context": "backend"
      },
      "deploy": {
        "startCommand": "sh -c \"celery -A app.tasks.celery_app.celery_app worker -Q pdf --concurrency=4 --loglevel=info -n pdf@railway\"",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    }
  }
}
